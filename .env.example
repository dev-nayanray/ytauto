# ── Copy this file to .env and fill in your real keys. ──────────────────────
# NEVER commit .env to git — it contains secrets.

# Anthropic — script generation & SEO
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Pexels — free stock footage
# Get yours at: https://www.pexels.com/api/ (free tier: 200 req/hour)
PEXELS_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# YouTube Data API v3 key — used ONLY for competition research (optional)
# Without this, keyword competition checking is skipped (fallback keywords used).
# Enable the YouTube Data API v3 in your Google Cloud project.
YOUTUBE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Path (relative to repo root) to the OAuth 2.0 client secrets JSON file.
# Download from: Google Cloud Console → APIs & Services → Credentials
# → Create Credentials → OAuth client ID → Desktop app → Download JSON
# Rename the downloaded file to client_secrets.json (or change this value).
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# edge-tts voice name (optional — defaults to en-US-GuyNeural)
# Run `edge-tts --list-voices` to see all available voices.
TTS_VOICE=en-US-GuyNeural

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot on Telegram → copy the id number
TELEGRAM_BOT_TOKEN=1234567890:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=123456789

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Leave blank — ytauto will auto-create a sheet and fill this in.
# Or paste an existing Google Sheet ID to use that sheet.
GOOGLE_SHEET_ID=

# ── Upload privacy (public = instant reach, private = manual review) ──────────
YOUTUBE_PRIVACY=public

# ── TikTok ────────────────────────────────────────────────────────────────────
# 1. Go to https://developers.tiktok.com/ → My Apps → Create App
# 2. Enable "Content Posting API" scope
# 3. Generate a long-lived access token for your account
TIKTOK_ACCESS_TOKEN=

# ── Facebook Page ─────────────────────────────────────────────────────────────
# 1. Go to https://developers.facebook.com/ → My Apps → Create App
# 2. Add "Pages API" + "Video" permissions
# 3. Generate a Page Access Token (never expires if extended)
# 4. Your Facebook Page numeric ID (from page URL or Business Manager)
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=
